# =============================================================================
# AI Gateway — .gitignore
# =============================================================================

# Environment / secrets — NEVER commit these
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/

# ML model checkpoints — can be large and are regenerated by training scripts
models/
!models/.gitkeep

# FAISS index — regenerated from Redis on startup
cache/
!cache/.gitkeep

# Pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# Benchmark output
benchmark_results/

# Generated test data
data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Docker
*.log
