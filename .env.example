# =============================================================================
# AI Gateway — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.  Lines with =<REQUIRED> must be set.
# Never commit .env to version control — it is listed in .gitignore.
#
# Variable naming convention:
#   TOP_LEVEL__          — root Settings fields
#   REDIS__              — RedisSettings (nested via env_nested_delimiter="__")
#   LANGFUSE__           — LangfuseSettings
#   PROVIDERS__          — ProviderSettings
#   SECURITY__           — SecuritySettings
#   CACHE__              — CacheSettings
# =============================================================================


# =============================================================================
# Gateway — top-level settings
# =============================================================================

# Human-readable service name (appears in logs and Langfuse traces)
APP_NAME="AI Gateway"

# Semantic version string
APP_VERSION="0.1.0"

# Runtime environment: development | staging | production
# Controls log verbosity and error detail in responses.
ENVIRONMENT=development

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Master API key that all clients must include in the Authorization: Bearer header.
# Generate a secure value with: python -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_API_KEY=<REQUIRED>


# =============================================================================
# Redis — distributed rate limiter and cache TTL store
# =============================================================================

# Redis hostname (use "redis" when running inside Docker Compose)
REDIS__HOST=localhost

# Redis port
REDIS__PORT=6379

# Redis password (leave blank to disable Redis AUTH)
REDIS__PASSWORD=

# Redis database index (0-15)
REDIS__DB=0

# Maximum number of connections in the async connection pool
REDIS__MAX_CONNECTIONS=20

# Sliding window size in seconds for rate limiting
REDIS__RATE_LIMIT_WINDOW_SECONDS=60


# =============================================================================
# Langfuse — observability and tracing
# =============================================================================

# Set to false to run without tracing (useful for local dev without Langfuse)
LANGFUSE__ENABLED=true

# Langfuse public key — found in Project Settings → API Keys
LANGFUSE__PUBLIC_KEY=<REQUIRED>

# Langfuse secret key — found in Project Settings → API Keys
LANGFUSE__SECRET_KEY=<REQUIRED>

# Langfuse server URL
# For cloud: https://cloud.langfuse.com
# For self-hosted (Docker Compose): http://langfuse:3000
LANGFUSE__HOST=https://cloud.langfuse.com

# Seconds between automatic event batch flushes
LANGFUSE__FLUSH_INTERVAL=0.5


# =============================================================================
# Provider API keys and base URLs
# =============================================================================

# ---- OpenAI -----------------------------------------------------------------

# OpenAI API key — https://platform.openai.com/api-keys
PROVIDERS__OPENAI_API_KEY=<REQUIRED>

# Base URL for the OpenAI API (override for Azure or compatible endpoints)
PROVIDERS__OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic --------------------------------------------------------------

# Anthropic API key — https://console.anthropic.com/settings/keys
PROVIDERS__ANTHROPIC_API_KEY=<REQUIRED>

# Anthropic API base URL
PROVIDERS__ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- Ollama (local models) --------------------------------------------------

# Ollama server base URL (use "http://ollama:11434" inside Docker Compose)
PROVIDERS__OLLAMA_BASE_URL=http://localhost:11434

# ---- Routing ----------------------------------------------------------------

# Default provider when the requested model alias is not in the registry.
# One of: openai | anthropic | local
PROVIDERS__DEFAULT_PROVIDER=openai

# Per-request timeout in seconds when calling upstream providers
PROVIDERS__REQUEST_TIMEOUT_SECONDS=60


# =============================================================================
# Security — prompt injection detection
# =============================================================================

# ---- Tier 1: pattern guard --------------------------------------------------

# Path to the JSON file containing injection regex patterns
SECURITY__PATTERN_FILE_PATH=gateway/security/patterns.json

# Set to false to skip regex scanning (not recommended in production)
SECURITY__PATTERN_GUARD_ENABLED=true

# ---- Tier 2: ML guard (DistilBERT classifier) --------------------------------

# Local path to the fine-tuned DistilBERT injection classifier checkpoint.
# Run scripts/train_classifier.py to generate this directory.
SECURITY__ML_MODEL_PATH=models/injection_classifier

# Set to false to disable ML scanning (faster, but less accurate)
SECURITY__ML_GUARD_ENABLED=true

# Confidence score (0.0–1.0) above which a prompt is classified as injection.
# Higher = fewer false positives, more false negatives.  Start with 0.85.
SECURITY__ML_CONFIDENCE_THRESHOLD=0.85

# ---- Tier 3: LLM judge (async, observational only) --------------------------

# Set to true to enable the async LLM judge for ambiguous Tier-2 scores.
# When enabled, requests with ML score in [LOW, HIGH] trigger a background
# LLM call that logs injection verdicts for training data collection.
# Does NOT block requests — Tier 3 is purely observational.
# Cost: ~$0.0003/call with Claude Haiku at $0.80/MTok input.
SECURITY__LLM_GUARD_ENABLED=false

# Model for the LLM judge. Claude Haiku is fastest and cheapest.
# Alternatives: gpt-4o-mini
SECURITY__LLM_GUARD_MODEL=claude-haiku-4-5-20251001

# Tier-2 score range that triggers the LLM judge [LOW, HIGH].
# Requests below LOW are confidently benign (skip judge).
# Requests above HIGH are blocked by Tier 2 (skip judge).
# The default [0.05, 0.40] targets the ambiguous zone.
SECURITY__LLM_GUARD_LOW_THRESHOLD=0.05
SECURITY__LLM_GUARD_HIGH_THRESHOLD=0.40


# =============================================================================
# Semantic cache — FAISS + sentence-transformers
# =============================================================================

# Set to false to disable caching entirely
CACHE__ENABLED=true

# Sentence-transformers model for prompt embedding.
# "all-MiniLM-L6-v2" is fast (384-dim). "all-mpnet-base-v2" is more accurate.
CACHE__EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Path where the FAISS index file is persisted across restarts
CACHE__FAISS_INDEX_PATH=cache/faiss.index

# Cosine similarity threshold for declaring a cache hit (0.0–1.0).
# Lower = more aggressive caching (risk of returning stale/wrong responses).
# Higher = stricter matching (lower hit rate but more accurate).  Start at 0.92.
CACHE__SIMILARITY_THRESHOLD=0.92

# Maximum number of vectors stored in the FAISS index.
# Old entries are evicted LRU-style when this limit is reached.
CACHE__MAX_CACHE_ENTRIES=10000

# Time-to-live in seconds for cached responses stored in Redis.
# 3600 = 1 hour.  Set to 0 to disable TTL (entries live until manually evicted).
CACHE__CACHE_TTL_SECONDS=3600


# =============================================================================
# Behavioral Contracts
# =============================================================================

# Directory containing contract JSON files (one per application)
CONTRACTS__CONTRACTS_DIR=contracts/

# Enable drift detection (tracks compliance scores in Redis over time)
CONTRACTS__DRIFT_ENABLED=true

# Recent window for drift comparison (hours). Default 24h.
CONTRACTS__DRIFT_RECENT_WINDOW_HOURS=24.0

# Baseline window for drift comparison (hours). Default 168h (7 days).
CONTRACTS__DRIFT_BASELINE_WINDOW_HOURS=168.0

# Relative compliance drop that triggers a drift alert (0.10 = 10%)
CONTRACTS__DRIFT_ALERT_THRESHOLD=0.10

# Minimum samples before drift detection fires (avoids false positives on sparse data)
CONTRACTS__DRIFT_MIN_SAMPLES=10

# How many days of compliance data to retain in Redis
CONTRACTS__DRIFT_RETENTION_DAYS=30

# How often to run periodic drift checks in the background (seconds)
CONTRACTS__DRIFT_CHECK_INTERVAL_SECONDS=300


# =============================================================================
# Langfuse self-hosted database (only needed when running Langfuse via Compose)
# =============================================================================

# PostgreSQL connection string for the Langfuse database
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse

# NextAuth secret — change this in production!
LANGFUSE_NEXTAUTH_SECRET=change-me-in-production

# Langfuse password salt — change this in production!
LANGFUSE_SALT=change-me-in-production
ANTHROPIC_API_KEY=<REQUIRED>